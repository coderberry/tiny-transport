{
  "name": "tiny-transport",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "pages:dev": "npm run build && npx wrangler pages dev dist",
    "pages:deploy": "npm run build && npx wrangler pages deploy dist --project-name=tiny-transport",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
